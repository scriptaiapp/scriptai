# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase (server-only, NEVER prefix with NEXT_PUBLIC_) — used by route handlers like /api/careers/apply
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Careers form recipients (optional overrides)
CAREERS_ADMIN_EMAIL=afrinxnahar@gmail.com
CAREERS_FROM_EMAIL=Creator AI Careers <notifications@yourdomain.com>

# Backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# AI Services
OPENAI_API_KEY=your-openai-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key

# Email
RESEND_API_KEY=your-resend-api-key
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret
